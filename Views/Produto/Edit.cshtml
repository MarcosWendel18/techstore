@model TechStore.Models.Produto

<h2>Editar Produto</h2>

<hr />

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id"/>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">

        <label asp-for="Nome"></label>

        <input asp-for="Nome" class="form-control"/>

    </div>

    <div class="mb-3">

        <label asp-for="Categoria"></label>

        <input asp-for="Categoria" class="form-control"/>

    </div>

    <div class="mb-3">

        <label asp-for="Descricao"></label>

        <textarea asp-for="Descricao"
                  class="form-control">
        </textarea>

    </div>

    <div class="mb-3">

        <label asp-for="Preco"></label>

        <input asp-for="Preco"
               class="form-control"/>

    </div>

    <div class="mb-3">

        <label asp-for="Estoque"></label>

        <input asp-for="Estoque"
               class="form-control"/>

    </div>

    <div class="mb-3">

        <label asp-for="Imagem"></label>

        <input asp-for="Imagem"
               class="form-control"/>

    </div>

    <button class="btn btn-primary">

        Salvar Alterações

    </button>

    <a asp-action="Index"
       class="btn btn-secondary">

        Voltar

    </a>

</form>

@section Scripts{

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}