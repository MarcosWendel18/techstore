@model TechStore.Models.Produto

<div class="row justify-content-center">
    <div class="col-md-6">

        <h2>Editar Produto</h2>

        <hr />

        <form asp-action="Edit" id="editForm" method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">

                <label asp-for="Nome" class="form-label"></label>

                <input asp-for="Nome" class="form-control" />

            </div>

            <div class="mb-3">

                <label asp-for="Categoria" class="form-label"></label>

                <input asp-for="Categoria" class="form-control" />

            </div>

            <div class="mb-3">

                <label asp-for="Descricao" class="form-label"></label>

                <textarea asp-for="Descricao" class="form-control">
        </textarea>

            </div>

            <div class="mb-3">

                <label asp-for="Preco" class="form-label"></label>

                <input type="text" name="Preco" value="@Model.Preco.ToString("N2")" class="form-control">

            </div>

            <div class="mb-3">

                <label asp-for="Estoque" class="form-label"></label>

                <input asp-for="Estoque" class="form-control" />

            </div>

            <div class="mb-3">

                <label asp-for="Imagem" class="form-label"></label>

                @if (!string.IsNullOrWhiteSpace(Model.Imagem))
                {
                    <img src="@Model.Imagem" class="img-thumbnail mb-3" style="max-width:200px;">
                }
                else
                {
                    <img src="@Url.Content("~/img/not_defined_img_product.png")" class="img-thumbnail mb-3"
                         style="max-width:200px;">
                }

                <input type="file" name="arquivoImagem" class="form-control" accept="image/*">

            </div>

            <button id="btnSalvar" class="btn btn-primary" disabled>

                Salvar Alterações

            </button>

            <a asp-action="Index" class="btn btn-secondary">

                Voltar

            </a>

        </form>

    </div>
</div>

<script>

    const formulario = document.getElementById("editForm");
    const botao = document.getElementById("btnSalvar");
    const estadoInicial = new FormData(formulario);

    formulario.addEventListener("input", () => {
        const atual = new FormData(formulario);
        let mudou = false;

        for (let chave of estadoInicial.keys()) {
            if (estadoInicial.get(chave) != atual.get(chave)) {
                mudou = true;
                break;
            }
        }

        botao.disabled = !mudou;
    });
</script>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}