@model IEnumerable<TechStore.Models.Produto>

<h2>Gerenciamento de Produtos</h2>

<hr />

<a asp-action="Create" class="btn btn-success mb-3">
    + Novo Produto
</a>

<form method="get" asp-action="Index" class="d-flex">

    <input type="text" name="pesquisa" value="@Context.Request.Query["pesquisa"]" class="form-control me-2" placeholder="Pesquisar produto..." />

    <button class="btn btn-primary">

        Buscar

    </button>

</form>

<table class="table table-striped table-bordered">

    <thead>

        <tr>

            <th>ID</th>

            <th>Nome</th>

            <th>Categoria</th>

            <th>Preço</th>

            <th>Estoque</th>

            <th>Ações</th>

        </tr>

    </thead>

    <tbody>

        @if (!Model.Any())
        {
            <tr>

                <td colspan="6" class="text-center">

                    Nenhum produto encontrado.

                </td>

            </tr>
        }
        else
        {
            @foreach (var produto in Model)
            {
                <tr>

                    <td>@produto.Id</td>

                    <td>@produto.Nome</td>

                    <td>@produto.Categoria</td>

                    <td>R$ @produto.Preco</td>

                    <td>@produto.Estoque</td>

                    <td>

                        <a asp-action="Edit" asp-route-id="@produto.Id" class="btn btn-warning btn-sm">

                            Editar

                        </a>

                        <a asp-action="Delete" asp-route-id="@produto.Id" class="btn btn-danger btn-sm">

                            X Excluir

                        </a>

                    </td>

                </tr>
            }
        }

    </tbody>

</table>