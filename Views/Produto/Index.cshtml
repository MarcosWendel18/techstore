@model IEnumerable<TechStore.Models.Produto>

<div class="row justify-content-center">
    <div class="col-md-10">

        <h2 class="title">Gerenciamento de Produtos</h2>

        <div class="d-flex justify-content-between align-items-center mb-3">

            <h2>Produtos</h2>

            <span class="badge bg-primary">

                @Model.Count() produto(s)

            </span>

        </div>

        <hr />

        <a asp-action="Create" class="btn btn-success mb-3">
            + Novo Produto
        </a>

        <form method="get" asp-action="Index" class="d-flex">

            <input type="text" name="pesquisa" value="@Context.Request.Query["pesquisa"]" class="form-control me-2"
                   placeholder="Pesquisar produto..." />

            <button class="btn btn-primary">

                Buscar

            </button>

        </form>

        <table class="table table-striped table-bordered">

            <thead>

                <tr>

                    <th>Imagem</th>

                    <th>ID</th>

                    <th>Nome</th>

                    <th>Categoria</th>

                    <th>Preço</th>

                    <th>Estoque</th>

                    <th>Ações</th>

                </tr>

            </thead>

            <tbody>

                @if (!Model.Any())
                {
                    <tr>

                        <td colspan="6" class="text-center">

                            Nenhum produto encontrado.

                        </td>

                    </tr>
                }
                else
                {
                    @foreach (var produto in Model)
                    {
                        <tr>
                            <td>

                                <img src="@Url.Content(
                                                                                  string.IsNullOrWhiteSpace(produto.Imagem)
                                                                                  ? "~/img/not_defined_img_product.png"
                                                                                  : produto.Imagem)" class="produto-thumb" />

                            </td>

                            <td>@produto.Id</td>

                            <td>@produto.Nome</td>

                            <td>@produto.Categoria</td>

                            <td>R$ @produto.Preco.ToString(format: "N2")</td>

                            <td>@produto.Estoque</td>

                            <td>

                                <a asp-action="Edit" asp-route-id="@produto.Id" class="btn btn-warning btn-sm">

                                    📝 Editar

                                </a>

                                <a asp-action="Delete" asp-route-id="@produto.Id" class="btn btn-danger btn-sm">

                                    ❌ Excluir

                                </a>

                            </td>

                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>
</div>