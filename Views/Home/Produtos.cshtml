@model IEnumerable<TechStore.Models.Produto>

<div class="text-center mb-5">

    <h1 class="display-5 fw-bold">

        Nosso Catálogo

    </h1>

    <p class="lead text-muted">

        Confira nossos produtos disponíveis.

    </p>

    <h3 class="text-muted text-center mb-4 fw-bold">

        @ViewBag.TotalProdutos produtos disponíveis

    </h3>

    <form method="get" class="mb-5">

        <div class="input-group">

            <input type="text" name="busca" class="form-control" placeholder="Pesquisar produto...">

            <button class="btn btn-primary">

                Buscar

            </button>

        </div>

    </form>

</div>

@if (!Model.Any())
{
    <div class="alert alert-info">

        Nenhum  disponível no momento.

    </div>
}
else
{

    <div class="row">

        @foreach (var produto in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">

                <div class="card produto-card h-100 shadow-sm">

                    <img src="@Url.Content(
                                                                                               string.IsNullOrWhiteSpace(produto.Imagem)
                                                                                               ? "~/img/not_defined_img_product.png"
                                                                                               : produto.Imagem)" class="card-img-top"
                         style="height:250px; object-fit:cover;">

                    <div class="card-body">

                        <h5 class="card-title fw-bold">

                            @produto.Nome

                        </h5>

                        <span class="badge bg-primary mb-3">

                            @produto.Categoria

                        </span>

                        <p class="card-text text-muted">

                            @(produto.Descricao.Length > 100
                                ? produto.Descricao.Substring(0, 100) + "..."
                                : produto.Descricao)

                        </p>

                    </div>

                    <div class="card-footer bg-white">

                        <div class="d-flex justify-content-between align-items-center">

                            <span class="fs-5 fw-bold text-success">

                                R$ @produto.Preco.ToString("N2")

                            </span>

                        </div>

                    </div>

                </div>

            </div>
        }
    </div>
}