@model IEnumerable<TechStore.Models.Produto>

<div class="hero-section text-center text-white rounded-4 p-3 mb-5">

    <h1 class="display-4 title fw-bold">
        Bem-vindo à TechStore
    </h1>

    <p class="lead">
        Tecnologia e inovação ao seu alcance.
    </p>

    <a asp-controller="Home" asp-action="Produtos" class="btn btn-light btn-lg mt-3">

        Ver Catálogo

    </a>

</div>

@if (!Model.Any())
{
    <div class="alert alert-info">

        Nenhum produto disponível no momento.

    </div>
}
else
{
    <h2 class="mb-4">
        Últimos Produtos
    </h2>

    <div class="row">

        @foreach (var produto in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card produto-card h-100 shadow-sm">

                    <img src="@Url.Content(
                                             string.IsNullOrWhiteSpace(produto.Imagem)
                                             ? "~/img/not_defined_img_product.png"
                                             : produto.Imagem)" class="produto-imagem">

                    <div class="card-body">

                        <h5 class="card-title">
                            @produto.Nome
                        </h5>

                        <span class="badge bg-primary mb-2">
                            @produto.Categoria
                        </span>

                        <p class="card-text">
                            @produto.Descricao
                        </p>

                    </div>

                    <div class="card-footer bg-white">

                        <strong class="text-success">
                            R$ @produto.Preco.ToString("N2")
                        </strong>

                    </div>

                </div>

            </div>
        }
    </div>
}

<div class="bg-light rounded-4 p-5 mt-5">

    <h2>Sobre a TechStore</h2>

    <p class="mb-0">

        A TechStore é uma loja especializada em produtos de tecnologia,
        oferecendo notebooks, periféricos, acessórios e equipamentos
        para atender às necessidades dos nossos clientes.

        Este sistema foi desenvolvido utilizando ASP.NET Core MVC
        como projeto acadêmico.

    </p>

</div>