@model TechStore.Models.LoginViewModel

<div class="row justify-content-center" style=" text-align: center;">

    <div class="col-md-5">

        <h2 class="title">Login Administrativo</h2>

        <form asp-action="Login" method="post">

            <div class="mb-3">
                <label asp-for="Email"></label>
                <input asp-for="Email" type="email" autocomplete="email" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Senha"></label>
                <input asp-for="Senha" type="password" autocomplete="current-password" class="form-control" />
            </div>

            <button class="btn btn-primary">
                Entrar
            </button>

        </form>

        @if (ViewBag.Erro != null)
        {
            <div class="alert alert-danger mt-3">
                @ViewBag.Erro
            </div>
        }

    </div>

</div>