<div
    style="max-width: 600px; margin: 20px auto; text-align: center; background-color: #d6d6d6; padding: 5px 20px; border-radius: 5px; box-shadow: 0 2px 4px rgba(155, 155, 155, 0.1);">
    <div class="mb-3">

        <h1 class="fw-bold title">

            Painel Administrativo

        </h1>

        <p class="text-muted">

            Gerencie os produtos da TechStore.

        </p>

    </div>

    <p>
        Bem-vindo,
        @Context.Session.GetString("Usuario")
    </p>

    
    <div class="row mb-3">

        <div class="col-md-6">

            <div class="card dashboard-card shadow-sm border-0 mb-2">

                <div class="card-body text-center ">

                    <h6 class="text-muted">

                        Produtos Cadastrados

                    </h6>

                    <h2 class="fw-bold text-primary">

                        @ViewBag.TotalProdutos

                    </h2>

                </div>

            </div>

        </div>

        <div class="col-md-6">

            <div class="card dashboard-card shadow-sm border-0 mb-2">

                <div class="card-body text-center ">

                    <h6 class="text-muted">

                        Categorias

                    </h6>

                    <h2 class="fw-bold text-primary">

                        @ViewBag.TotalCategorias

                    </h2>

                </div>

            </div>

        </div>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body m-auto">

            <h4 class="mb-4">

                Ações Rápidas

            </h4>

            <div class="d-flex gap-3 flex-wrap">

                <a asp-controller="Produto" asp-action="Create" class="btn btn-primary">

                    Novo Produto

                </a>

                <a asp-controller="Produto" asp-action="Index" class="btn btn-outline-primary">

                    Gerenciar Produtos

                </a>

                <a asp-controller="Home" asp-action="Produtos" class="btn btn-outline-secondary">

                    Ver Catálogo

                </a>

            </div>

        </div>

    </div>

    <div class="card shadow-sm border-0 mt-4">

        <div class="card-body">

            <h4 class="mb-3">

                Últimos Produtos

            </h4>

            <table class="table">

                <thead>

                    <tr>

                        <th>Nome</th>
                        <th>Categoria</th>
                        <th>Preço</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var produto in ViewBag.UltimosProdutos)
                    {
                        <tr>

                            <td>@produto.Nome</td>

                            <td>@produto.Categoria</td>

                            <td>
                                R$ @produto.Preco.ToString("N2")
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <div class="m-4">
        <a class="btn btn-danger" asp-controller="Auth" asp-action="Logout">

            Logout

        </a>
    </div>
</div>